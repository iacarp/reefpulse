{
  "expo": {
    "name": "ReefPulse",
    "slug": "reefpulse",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#020617",
    "primaryColor": "#06b6d4",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reefpulse.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.reefpulse.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#020617"
      },
      "permissions": ["NOTIFICATIONS", "VIBRATE", "RECEIVE_BOOT_COMPLETED"]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "SET_AFTER_EAS_INIT"
      }
    }
  }
}
